# Property360 web — environment variables.
# Copy to .env.local for dev; set the same keys in Vercel for production.

# Backend API base (already used by the app).
NEXT_PUBLIC_API_URL=https://api.property360.africa/api/v1

# ── Meta Pixel + Conversions API ──────────────────────────────────────────
# Until these are set, all Meta tracking no-ops and the site behaves normally.

# Pixel/dataset ID from Meta Events Manager. Public (ships to the browser).
NEXT_PUBLIC_META_PIXEL_ID=

# Same Pixel ID, readable server-side by the CAPI relay. Set to the same value.
# (The relay falls back to NEXT_PUBLIC_META_PIXEL_ID if this is unset.)
META_PIXEL_ID=

# Conversions API access token (Events Manager → Settings → Generate token).
# SECRET — never prefix with NEXT_PUBLIC. Server-only.
META_CAPI_ACCESS_TOKEN=

# Optional: paste the test-event code from Events Manager → Test Events while
# validating, then remove it so live events stop being flagged as tests.
META_TEST_EVENT_CODE=
