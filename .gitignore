# content, generated quote-cards & banners, design briefs, planning docs,
# and AI scratch dirs. Collateral, not product code.
/marketing/
pitch-deck/
presentation/
public/launch/
docs/launch/
launch-content/
.superpowers/
.playwright-mcp/
*.pptx
*.keynote
