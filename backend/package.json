{
  "name": "property360-backend",
  "version": "1.0.0",
  "description": "Property360 - Property Management API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:nodemon": "nodemon --exec ts-node src/server.ts --ext ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "property",
    "management",
    "nigeria",
    "landlord",
    "tenant"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "3.0.3",
    "cors": "2.8.6",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-validator": "7.3.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.1.6",
    "morgan": "1.10.1",
    "twilio": "5.12.1",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/node": "25.2.1",
    "@types/uuid": "10.0.0",
    "nodemon": "3.1.11",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.9.3"
  }
}
