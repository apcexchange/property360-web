# Server Configuration
NODE_ENV=development
PORT=5001

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Cors
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

MONGODB_USER_NAME=your_mongodb_username
MONGODB_USER_PASSWORD=your_mongodb_password

# Twilio Configuration (SMS OTP & Notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid
TWILIO_PHONE_NUMBER=+1234567890

# Resend Configuration (Email OTP) - Deprecated, using SendGrid instead
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=Property360 <onboarding@resend.dev>

# SendGrid Configuration (Email)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=your_email@example.com
SENDGRID_FROM_NAME=Property360

# Cloudinary Configuration (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# DocuSeal Configuration (E-Signature)
# Get your API key from https://docuseal.co/settings/api
DOCUSEAL_API_KEY=your_docuseal_api_key
DOCUSEAL_API_URL=https://docuseal.com
DOCUSEAL_WEBHOOK_SECRET=your_webhook_secret

# Paystack Configuration (Online Payments)
# Get your keys from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
PAYSTACK_CALLBACK_URL=https://yourapp.com/payment/callback
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
